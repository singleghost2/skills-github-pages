source "https://rubygems.org"

# 使用 github-pages gem，锁定与 GitHub Pages 线上一致的 Jekyll 及插件版本，
# 便于本地 `bundle exec jekyll serve` 预览且不会出现线上/本地差异。
gem "github-pages", group: :jekyll_plugins

# Windows / JRuby 缺少时区数据库，补上纯 Ruby 实现（安装安全，无需编译）
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
